generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  referralCode   String    @unique
  referralCredit Int       @default(0)
  createdAt      DateTime  @default(now())

  sessions       Session[]
  purchases      Purchase[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  input     String
  output    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

model Purchase {
  id              String   @id @default(cuid())
  stripeSessionId String   @unique
  userId          String
  referralUsed    String?
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id])
}